# ============================================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ — TERMINAL PRIMORSKIY
# Скопируйте этот файл в .env.local и заполните значения
# НИКОГДА не коммитьте .env.local в репозиторий!
# ============================================================

# --- NEXTJS ---
NEXT_PUBLIC_SITE_URL=https://terminal-primorskiy.ru

# --- ФОРМА / EMAIL ---
# Выберите один из адаптеров: smtp | resend | webhook

FORM_ADAPTER=smtp  # smtp | resend | webhook

# SMTP (если FORM_ADAPTER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM="Терминал Приморский <noreply@example.com>"
SMTP_TO=manager@example.com

# Resend (если FORM_ADAPTER=resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM="Терминал Приморский <noreply@example.com>"
RESEND_TO=manager@example.com

# Webhook (если FORM_ADAPTER=webhook)
WEBHOOK_URL=https://hooks.example.com/your-webhook-id
WEBHOOK_SECRET=your_webhook_secret

# --- CRM (опционально) ---
# Bitrix24
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/xxxxx/

# amoCRM
AMOCRM_SUBDOMAIN=your-subdomain
AMOCRM_CLIENT_ID=your_client_id
AMOCRM_CLIENT_SECRET=your_client_secret
AMOCRM_REFRESH_TOKEN=your_refresh_token

# --- АНАЛИТИКА (публичные ID — можно в NEXT_PUBLIC_) ---
NEXT_PUBLIC_YM_ID=           # ID счётчика Яндекс Метрики (например: 12345678)
NEXT_PUBLIC_GA_ID=           # ID потока GA4 (например: G-XXXXXXXXXX)

# --- БЕЗОПАСНОСТЬ ---
# CSP nonce секрет (для Content-Security-Policy)
CSP_SECRET=your_random_csp_secret_32chars

# Rate limiting (кол-во запросов формы с одного IP в час)
RATE_LIMIT_MAX=10

# Максимальный размер загружаемого файла (в байтах)
MAX_FILE_SIZE=5242880  # 5 MB

# --- КАРТЫ ---
# Яндекс Карты API ключ (для встраивания карты)
NEXT_PUBLIC_YANDEX_MAPS_KEY=  # TODO: получить на developer.tech.yandex.ru
